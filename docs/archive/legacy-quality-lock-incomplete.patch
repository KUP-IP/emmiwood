+++ migrations/0018_emmiwood_booking_idempotency.sql
+-- Make public appointment creation safely retryable across transient network or edge failures.
+ALTER TABLE emmiwood_appointments ADD COLUMN booking_request_id TEXT;
+ALTER TABLE emmiwood_appointments ADD COLUMN booking_request_fingerprint TEXT;
+CREATE UNIQUE INDEX IF NOT EXISTS idx_emmiwood_appointments_booking_request
+  ON emmiwood_appointments(booking_request_id)
+  WHERE booking_request_id IS NOT NULL;
